// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}
enum Role {
  USER
  ADMIN
}
model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  name         String
  avatarUrl    String?
  age          Int?
  password     String?
  googleId     String?      @unique
  authProvider AuthProvider @default(LOCAL)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  role  String @default("USER")

  progress UserProgress[]
  stats    UserStats?
  decks    Deck[]
  studyLogs StudyLog[]
  dictionaryHistory DictionaryHistory[]
  favoriteWords FavoriteWord[]
  chatMessages ChatMessage[]
  quests   UserQuest[]
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model UserStats {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  dailyTarget           Int       @default(20)
  lastStudyDate         DateTime?
  xp                    Int       @default(0)
  coins                 Int       @default(0)
  lastGardenHarvestDate DateTime?
  streakFreezeCount     Int       @default(0)
  xpBoostCount          Int       @default(0)
  xpBoostUntil          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deck {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  isSystem    Boolean  @default(false)
  isPublic    Boolean  @default(false)
  shareCode   String?  @unique
  createdAt   DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  flashcards Flashcard[]
}

model Flashcard {
  id Int @id @default(autoincrement())

  deckId Int

  hanzi          String
  pinyin         String
  meaning        String
  radicals       String?
  strokeData     String?
  audioUrl       String?
  exampleHanzi   String?
  examplePinyin  String?
  exampleMeaning String?

  deck       Deck           @relation(fields: [deckId], references: [id])
  progresses UserProgress[]
  studyLogs  StudyLog[]

  @@unique([deckId, hanzi, meaning])
}

model UserProgress {
  id             Int      @id @default(autoincrement())
  userId         Int
  flashcardId    Int
  interval       Int      @default(0)
  easeFactor     Float    @default(2.5)
  repetitions    Int      @default(0)
  nextReviewDate DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
}

model StudyLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  cardId    Int
  rating    Int
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model DictionaryHistory {
  id            Int      @id @default(autoincrement())
  userId        Int
  hanzi         String
  pinyin        String?
  sv            String?
  vi            String?
  aiExplanation String?  @db.Text
  aiGeneratedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hanzi])
}

model FavoriteWord {
  id       Int      @id @default(autoincrement())
  userId   Int
  hanzi    String
  pinyin   String?
  sv       String?
  vi       String?
  createdAt DateTime @default(now()) 

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, hanzi])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String   // "user" hoặc "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DictionaryWord {
  id  Int      @id @default(autoincrement())
  s   String   // Giản thể
  t   String?  // Phồn thể
  p   String?  // Pinyin
  pt  String?  // Pinyin số
  sp  String?  // Pinyin trơn
  b   Int?     // Số nét
  vi  String?  // Nghĩa tiếng Việt
  sv  String?  // Âm Hán Việt
  en  String[] // Mảng nghĩa tiếng Anh
  hsk Int?     // Cấp độ HSK

  @@index([s])
  @@index([sp])
  @@index([hsk])
  @@index([sv])
  @@index([p])
  @@index([pt])
}

model UserQuest {
  id          Int      @id @default(autoincrement())
  userId      Int
  questType   String   // "STUDY_CARDS", "AI_CHAT", "DICTIONARY_LOOKUP", "FAVORITE_WORD", "PLAY_GAME", "WRITE_PRACTICE", "SPEAK_PRACTICE"
  title       String
  description String?
  target      Int
  progress    Int      @default(0)
  xpReward    Int      @default(20)
  coinReward  Int      @default(10)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  dateStr     String   // YYYY-MM-DD local date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateStr])
}